{
  "name": "SplashView",
  "version": "0.0.18",
  "summary": "A lightweight splash screen library for React Native.",
  "homepage": "https://github.com/jagnesh/react-native-splash-view#readme",
  "license": "MIT",
  "authors": "Jagnesh Chawla <jagnesh_chawla@hotmail.com> (https://github.com/jagnesh)",
  "module_name": "SplashView",
  "platforms": {
    "ios": "15.1"
  },
  "source": {
    "git": "https://github.com/jagnesh/react-native-splash-view.git",
    "tag": "0.0.18"
  },
  "public_header_files": "ios/**/*.h",
  "source_files": "ios/**/*.{h,m,mm,cpp,swift}",
  "preserve_paths": "ios/SplashView-Bridging-Header.h",
  "dependencies": {
    "React-RCTFabric": [],
    "React-Core": [],
    "RCT-Folly": [
      "2024.11.18.00"
    ],
    "glog": [],
    "ReactCodegen": [],
    "RCTRequired": [],
    "RCTTypeSafety": [],
    "ReactCommon/turbomodule/bridging": [],
    "ReactCommon/turbomodule/core": [],
    "React-NativeModulesApple": [],
    "Yoga": [],
    "React-Fabric": [],
    "React-graphics": [],
    "React-utils": [],
    "React-featureflags": [],
    "React-debug": [],
    "React-ImageManager": [],
    "React-rendererdebug": [],
    "DoubleConversion": [],
    "hermes-engine": []
  },
  "swift_versions": "5.0",
  "requires_arc": true,
  "compiler_flags": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32",
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/boost\" \"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32",
    "OTHER_SWIFT_FLAGS": "$(inherited)"
  },
  "swift_version": "5.0"
}
