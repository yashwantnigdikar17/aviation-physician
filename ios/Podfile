require 'fileutils'
require 'pathname'
require 'shellwords'

source 'https://github.com/CocoaPods/Specs.git'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# Hermes build scripts source `REACT_NATIVE_PATH` from the repo that contains this Podfile.
# If `node_modules` is missing here, Xcode fails with: with-environment.sh: No such file or directory.
repo_root = File.expand_path(File.join(__dir__, '..'))
with_env = File.join(repo_root, 'node_modules', 'react-native', 'scripts', 'xcode', 'with-environment.sh')
unless File.exist?(with_env)
  Pod::UI.puts '[!] react-native is not installed next to this ios/ folder.'.red
  Pod::UI.puts "    Expected: #{with_env}".yellow
  Pod::UI.puts "    From repo root run: cd \"#{repo_root}\" && npm install".yellow
  if repo_root.include?('iCloud Drive')
    Pod::UI.puts '    Tip: iCloud copies often lack a full node_modules tree; use a local clone and open that .xcworkspace in Xcode.'.yellow
  end
  abort('Aborting pod install until node_modules/react-native exists.')
end

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'TiaAviation' do
  config = use_native_modules!

  # Use modular headers only for Firebase pods that require Swift static integration.
  pod 'GoogleUtilities', :modular_headers => true
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'FirebaseFirestore', :modular_headers => true
  pod 'FirebaseFirestoreInternal', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :fabric_enabled => false,
    :new_arch_enabled => false,
    :hermes_enabled => true
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # gRPC in this dependency set is not fully C++20-compatible.
    # Force C++17 for gRPC-related pod targets.
    installer.pods_project.targets.each do |target|
      next unless target.name.start_with?('gRPC') || target.name == 'BoringSSL-GRPC'

      target.build_configurations.each do |build_config|
        build_config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++17'
        flags = build_config.build_settings['OTHER_CPLUSPLUSFLAGS']
        if flags
          flags = [flags] unless flags.is_a?(Array)
          flags = flags.reject { |f| f.include?('-std=c++20') || f.include?('-std=gnu++20') }
          flags << '-std=gnu++17'
          build_config.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags
        else
          build_config.build_settings['OTHER_CPLUSPLUSFLAGS'] = ['$(inherited)', '-std=gnu++17']
        end

        # Xcode 16 + some gRPC podspec combos can leak a bare '-G' flag on iOS.
        # That flag is unsupported for arm64-apple-ios and breaks BoringSSL build.
        %w[OTHER_CFLAGS OTHER_CPLUSPLUSFLAGS].each do |key|
          raw = build_config.build_settings[key]
          next if raw.nil?
          normalized = raw.is_a?(Array) ? raw : [raw]
          normalized = normalized.reject do |f|
            # Keep debug flags like -g, but drop malformed -G* flags.
            s = f.to_s.strip
            s == '-G' || (s.start_with?('-G') && !s.start_with?('-g'))
          end
          build_config.build_settings[key] = normalized
        end
      end

      # Some podspecs inject per-file COMPILER_FLAGS that can include malformed -G*.
      target.source_build_phase.files.each do |build_file|
        next if build_file.settings.nil?
        next if build_file.settings['COMPILER_FLAGS'].nil?

        flags = Shellwords.split(build_file.settings['COMPILER_FLAGS'].to_s)
        flags = flags.reject do |f|
          s = f.to_s.strip
          s == '-G' || (s.start_with?('-G') && !s.start_with?('-g'))
        end
        build_file.settings['COMPILER_FLAGS'] = flags.join(' ')
      end
    end

    # Patch known gRPC 1.62.x + Xcode/Clang compatibility issues.
    grpc_patch_roots = ['gRPC-Core', 'gRPC-C++']
    grpc_patch_roots.each do |root|
      promise_like = File.join(__dir__, "Pods/#{root}/src/core/lib/promise/detail/promise_like.h")
      basic_seq = File.join(__dir__, "Pods/#{root}/src/core/lib/promise/detail/basic_seq.h")

      if File.exist?(promise_like)
        FileUtils.chmod('u+w', promise_like)
        content = File.read(promise_like)
        content = content.gsub('#include <utility>', "#include <utility>\n#include <type_traits>")
        content = content.gsub('typename std::result_of<F()>::type', 'typename std::invoke_result<F>::type')
        File.write(promise_like, content)
      end

      if File.exist?(basic_seq)
        FileUtils.chmod('u+w', basic_seq)
        content = File.read(basic_seq)
        content = content.gsub('Traits::template CallSeqFactory(', 'Traits::CallSeqFactory(')
        File.write(basic_seq, content)
      end
    end

    # fmt 11.0.x + Apple Clang: FMT_STRING/basic_format_string consteval can fail with
    # "Call to consteval function ... is not a constant expression". Force FMT_USE_CONSTEVAL off
    # after auto-detection (unique anchor) so FMT_CONSTEVAL becomes empty.
    fmt_base = File.join(__dir__, 'Pods/fmt/include/fmt/base.h')
    if File.exist?(fmt_base)
      FileUtils.chmod('u+w', fmt_base)
      text = File.read(fmt_base)
      marker = 'FMT_FORCE_NO_CONSTEVAL_POD'
      unless text.include?(marker)
        needle = <<~'PATCH'
#else
#  define FMT_USE_CONSTEVAL 0
#endif
#if FMT_USE_CONSTEVAL
#  define FMT_CONSTEVAL consteval
PATCH
        replacement = <<~'PATCH'
#else
#  define FMT_USE_CONSTEVAL 0
#endif
#undef FMT_USE_CONSTEVAL
#define FMT_USE_CONSTEVAL 0  // #{marker}
#if FMT_USE_CONSTEVAL
#  define FMT_CONSTEVAL consteval
PATCH
        replacement = replacement.sub('#{marker}', marker)
        if text.include?(needle)
          File.write(fmt_base, text.sub(needle, replacement))
        else
          Pod::UI.warn("[Podfile] fmt/base.h patch anchor not found; fmt consteval errors may persist. Re-run pod install.")
        end
      end
    end

    # Some dependency combinations inject a stale weak framework linker flag
    # for FirebaseFirestoreInternal, but that target is linked as a static lib.
    # Remove it to prevent "framework not found" at app link time.
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.native_targets.each do |native_target|
        native_target.build_configurations.each do |build_config|
          flags = build_config.build_settings['OTHER_LDFLAGS']
          next if flags.nil?

          flags = [flags] unless flags.is_a?(Array)
          cleaned = []
          i = 0
          while i < flags.length
            token = flags[i].to_s
            if token == '-weak_framework' && flags[i + 1].to_s == 'FirebaseFirestoreInternal'
              i += 2
              next
            end
            cleaned << token
            i += 1
          end
          build_config.build_settings['OTHER_LDFLAGS'] = cleaned
        end
      end
      aggregate_target.user_project.save
    end

    # As a final safeguard, scrub all generated app xcconfig files where CocoaPods
    # may re-inject this flag during integration (target names can vary).
    Dir.glob(File.join(__dir__, 'Pods/Target Support Files/Pods-*/Pods-*.xcconfig')).each do |xcconfig_path|
      next unless File.exist?(xcconfig_path)
      FileUtils.chmod('u+w', xcconfig_path)
      text = File.read(xcconfig_path)
      text = text.gsub(/\s-weak_framework\s+"?FirebaseFirestoreInternal"?/, '')
      File.write(xcconfig_path, text)
    end

    # Hermes runs `. "$REACT_NATIVE_PATH/scripts/xcode/with-environment.sh"`. CocoaPods can freeze
    # REACT_NATIVE_PATH to an absolute path from the machine where `pod install` last ran, which
    # breaks when Xcode builds another checkout (e.g. iCloud vs ~/Documents) while reusing the same
    # DerivedData. Force a value derived from PODS_ROOT so it always matches the open workspace.
    pods_root = Pathname.new(installer.sandbox.root.to_s)
    ios_root = pods_root.parent
    rn_root = Pathname.new(File.expand_path(config[:reactNativePath], ios_root.to_s))
    rn_relative = begin
      rn_root.relative_path_from(pods_root).to_s
    rescue ArgumentError
      '../../node_modules/react-native'
    end
    react_native_path_setting = "$(PODS_ROOT)/#{rn_relative}"
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        build_config.build_settings['REACT_NATIVE_PATH'] = react_native_path_setting
      end
    end

    Dir.glob(File.join(__dir__, 'Pods/Target Support Files/**/*.xcconfig')).each do |xcconfig_path|
      next unless File.exist?(xcconfig_path)
      FileUtils.chmod('u+w', xcconfig_path)
      text = File.read(xcconfig_path)
      next unless text.match?(/^REACT_NATIVE_PATH\s*=/)

      text = text.gsub(/^REACT_NATIVE_PATH\s*=\s*.*$/, "REACT_NATIVE_PATH = #{react_native_path_setting}")
      File.write(xcconfig_path, text)
    end

    installer.pods_project.save
  end
end
